
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Playwright MCP Test Execution Report</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-gradient: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
            --panel-bg: rgba(30, 41, 59, 0.7);
            --border-color: rgba(255, 255, 255, 0.08);
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --success-color: #10b981;
            --success-glow: rgba(16, 185, 129, 0.25);
            --warning-color: #f59e0b;
            --danger-color: #ef4444;
            --info-color: #3b82f6;
            --accent-glow: rgba(99, 102, 241, 0.15);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-gradient);
            color: var(--text-primary);
            margin: 0;
            padding: 40px 20px;
            min-height: 100vh;
            display: flex;
            justify-content: center;
        }

        .container {
            max-width: 1000px;
            width: 100%;
        }

        /* Header Style */
        .header {
            text-align: center;
            margin-bottom: 40px;
        }

        .header h1 {
            font-size: 2.5rem;
            font-weight: 700;
            margin: 0 0 10px 0;
            background: linear-gradient(90deg, #60a5fa, #a78bfa, #f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.02em;
        }

        .header p {
            color: var(--text-secondary);
            font-size: 1.1rem;
            margin: 0;
        }

        /* Metadata Cards Grid */
        .meta-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .meta-card {
            background: var(--panel-bg);
            border: 1px solid var(--border-color);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .meta-card:hover {
            transform: translateY(-2px);
            border-color: rgba(255, 255, 255, 0.15);
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3);
        }

        .meta-card h3 {
            margin: 0 0 8px 0;
            color: var(--text-secondary);
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 600;
        }

        .meta-card .value {
            font-size: 1.25rem;
            font-weight: 600;
            margin: 0;
        }

        .meta-card .badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background-color: var(--success-glow);
            color: var(--success-color);
            padding: 6px 16px;
            border-radius: 9999px;
            font-size: 0.95rem;
            font-weight: 700;
            border: 1px solid rgba(16, 185, 129, 0.4);
            box-shadow: 0 0 15px var(--success-glow);
        }

        /* Detail Sections */
        .section-card {
            background: var(--panel-bg);
            border: 1px solid var(--border-color);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
        }

        .section-card h2 {
            font-size: 1.4rem;
            margin-top: 0;
            margin-bottom: 20px;
            color: #f8fafc;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .step-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .step-item {
            display: flex;
            align-items: flex-start;
            gap: 15px;
            padding: 15px;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.03);
            margin-bottom: 10px;
        }

        .step-number {
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--info-color);
            color: #fff;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            font-weight: 600;
            font-size: 0.9rem;
            flex-shrink: 0;
        }

        .step-content {
            flex-grow: 1;
        }

        .step-title {
            font-weight: 600;
            margin-bottom: 4px;
        }

        .step-desc {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        /* Console Logs */
        .log-container {
            font-family: 'Fira Code', monospace;
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 15px;
            max-height: 250px;
            overflow-y: auto;
            font-size: 0.85rem;
        }

        .log-entry {
            display: flex;
            margin-bottom: 8px;
            line-height: 1.5;
        }

        .log-entry:last-child {
            margin-bottom: 0;
        }

        .log-timestamp {
            color: #64748b;
            margin-right: 15px;
            flex-shrink: 0;
        }

        .log-type {
            font-weight: 600;
            margin-right: 10px;
            flex-shrink: 0;
        }

        .log-type.error { color: var(--danger-color); }
        .log-type.warn { color: var(--warning-color); }
        .log-type.info { color: var(--info-color); }
        .log-type.log { color: #f8fafc; }

        .log-msg {
            color: #e2e8f0;
            word-break: break-all;
        }

        /* DOM Snapshot Preview */
        .snapshot-tree {
            font-family: 'Fira Code', monospace;
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 20px;
            font-size: 0.85rem;
            color: #cbd5e1;
            line-height: 1.6;
        }

        .snapshot-tag {
            color: #f472b6;
            font-weight: 600;
        }

        .snapshot-attr {
            color: #60a5fa;
        }

        .snapshot-text {
            color: #a78bfa;
        }

        .indent-1 { padding-left: 20px; }
        .indent-2 { padding-left: 40px; }
        .indent-3 { padding-left: 60px; }
        .indent-4 { padding-left: 80px; }

    </style>
</head>
<body>

    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>Test Execution Report</h1>
            <p>VWO Application Automation via Playwright MCP</p>
        </div>

        <!-- Metadata Grid -->
        <div class="meta-grid">
            <div class="meta-card">
                <h3>Test Case ID</h3>
                <p class="value" style="font-family: 'Fira Code', monospace;">TC-001</p>
            </div>
            <div class="meta-card">
                <h3>Execution Date</h3>
                <p class="value">May 27, 2026</p>
            </div>
            <div class="meta-card">
                <h3>Target URL</h3>
                <p class="value" style="font-size: 1.1rem; color: var(--info-color);">app.vwo.com/#/login</p>
            </div>
            <div class="meta-card" style="text-align: center;">
                <h3>Status</h3>
                <div class="badge">PASSED</div>
            </div>
        </div>

        <!-- Steps Executed -->
        <div class="section-card">
            <h2>
                <svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                Executed Steps
            </h2>
            <ul class="step-list">
                <li class="step-item">
                    <div class="step-number">1</div>
                    <div class="step-content">
                        <div class="step-title">Navigate to the login page</div>
                        <div class="step-desc">Navigated to <code>https://app.vwo.com/#/login</code> successfully using the <code>browser_navigate</code> tool.</div>
                    </div>
                </li>
            </ul>
        </div>

        <!-- Console logs -->
        <div class="section-card">
            <h2>
                <svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2 5a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V5zm3.293 1.293a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 01-1.414-1.414L7.586 10 4.707 7.121a1 1 0 010-1.414zM11 12a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"></path></svg>
                Console Logs
            </h2>
            <div class="log-container">
                <div class="log-entry">
                    <span class="log-timestamp">[1294ms]</span>
                    <span class="log-type warn">[WARN]</span>
                    <span class="log-msg">WARNING! This section is intended for developers only. Do not enter or paste code...</span>
                </div>
                <div class="log-entry">
                    <span class="log-timestamp">[1803ms]</span>
                    <span class="log-type error">[ERROR]</span>
                    <span class="log-msg">Failed to load resource: the server responded with a status of 401 () @ https://app.vwo.com/login</span>
                </div>
                <div class="log-entry">
                    <span class="log-timestamp">[2301ms]</span>
                    <span class="log-type info">[INFO]</span>
                    <span class="log-msg">Input elements should have autocomplete attributes (suggested: "current-password", "new-password")</span>
                </div>
                <div class="log-entry">
                    <span class="log-timestamp">[8377ms]</span>
                    <span class="log-type error">[ERROR]</span>
                    <span class="log-msg">Uncaught TypeError: Cannot read properties of undefined (reading 'element') at dev.visualwebsiteoptimizer.com/j.php</span>
                </div>
            </div>
        </div>

        <!-- DOM Snapshot structure -->
        <div class="section-card">
            <h2>
                <svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"></path></svg>
                DOM Accessibility Tree Snapshot
            </h2>
            <div class="snapshot-tree">
                <div>- <span class="snapshot-tag">main</span> <span class="snapshot-attr">"Application main content"</span>:</div>
                <div class="indent-1">- <span class="snapshot-tag">img</span> <span class="snapshot-attr">"VWO"</span></div>
                <div class="indent-1">- <span class="snapshot-tag">list</span>:</div>
                <div class="indent-2">- <span class="snapshot-tag">textbox</span> <span class="snapshot-attr">"Email address"</span> [active] <span class="snapshot-text">placeholder: "Enter email ID"</span></div>
                <div class="indent-2">- <span class="snapshot-tag">textbox</span> <span class="snapshot-attr">"Password"</span> <span class="snapshot-text">placeholder: "Enter password"</span></div>
                <div class="indent-2">- <span class="snapshot-tag">button</span> <span class="snapshot-attr">"Toggle password visibility"</span></div>
                <div class="indent-2">- <span class="snapshot-tag">button</span> <span class="snapshot-attr">"Forgot Password?"</span></div>
                <div class="indent-2">- <span class="snapshot-tag">checkbox</span> <span class="snapshot-text">"Remember me"</span></div>
                <div class="indent-2">- <span class="snapshot-tag">button</span> <span class="snapshot-attr">"Sign in"</span></div>
                <div class="indent-2">- <span class="snapshot-tag">heading</span> <span class="snapshot-attr">"Or"</span> [level=6]</div>
                <div class="indent-2">- <span class="snapshot-tag">button</span> <span class="snapshot-attr">"Sign in with Google"</span></div>
                <div class="indent-2">- <span class="snapshot-tag">button</span> <span class="snapshot-attr">"Sign in using SSO"</span></div>
                <div class="indent-2">- <span class="snapshot-tag">button</span> <span class="snapshot-attr">"Sign in with Passkey"</span></div>
                <div class="indent-2">- <span class="snapshot-tag">link</span> <span class="snapshot-attr">"Start a FREE TRIAL"</span></div>
            </div>
        </div>
    </div>

</body>
</html>
